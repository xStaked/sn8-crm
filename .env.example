# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sn8_wpp_crm

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=8h

# Seed / bootstrap (first socio user)
SEED_USER_EMAIL=socio@example.com
SEED_USER_PASSWORD=change-me-please

# Kapso.ai
KAPSO_API_KEY=your-kapso-api-key
KAPSO_PHONE_NUMBER_ID=your-phone-number-id
KAPSO_WEBHOOK_SECRET=your-webhook-signing-secret

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_MS=30000

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth cookies / CORS
AUTH_COOKIE_SAME_SITE=strict
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=.sn8labs.com
