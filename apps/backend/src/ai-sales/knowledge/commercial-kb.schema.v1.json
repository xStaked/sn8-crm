{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sn8.local/schemas/commercial-kb.schema.v1.json",
  "title": "SN8 Commercial Knowledge Base v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "updatedAt",
    "currency",
    "taxonomies",
    "offerLadder",
    "entries"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "2026-04-08.kb-commercial-v1"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "currency": {
      "type": "string",
      "const": "COP"
    },
    "taxonomies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categories", "complexity", "integration"],
      "properties": {
        "categories": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "landing_marketing",
              "web_operativa",
              "crm_sales",
              "vertical_saas",
              "automation_ia"
            ]
          }
        },
        "complexity": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        },
        "integration": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["none", "standard", "advanced"]
          }
        }
      }
    },
    "offerLadder": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tierId",
          "name",
          "durationWeeksMin",
          "durationWeeksMax",
          "priceMin",
          "priceMax",
          "notes"
        ],
        "properties": {
          "tierId": { "type": "string" },
          "name": { "type": "string" },
          "durationWeeksMin": { "type": "integer", "minimum": 1 },
          "durationWeeksMax": { "type": "integer", "minimum": 1 },
          "priceMin": { "type": "integer", "minimum": 1 },
          "priceMax": { "type": "integer", "minimum": 1 },
          "notes": { "type": "string" }
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "serviceId",
          "category",
          "complexity",
          "integration",
          "problemSolved",
          "scopeIncluded",
          "scopeExcluded",
          "durationWeeksMin",
          "durationWeeksMax",
          "priceMin",
          "priceTarget",
          "priceMax",
          "paymentTerms",
          "assumptions",
          "risks",
          "upsells",
          "mvpFirst",
          "source"
        ],
        "properties": {
          "serviceId": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "landing_marketing",
              "web_operativa",
              "crm_sales",
              "vertical_saas",
              "automation_ia"
            ]
          },
          "complexity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "integration": {
            "type": "string",
            "enum": ["none", "standard", "advanced"]
          },
          "problemSolved": { "type": "string", "minLength": 1 },
          "scopeIncluded": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "scopeExcluded": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "durationWeeksMin": { "type": "integer", "minimum": 1 },
          "durationWeeksMax": { "type": "integer", "minimum": 1 },
          "priceMin": { "type": "integer", "minimum": 1 },
          "priceTarget": { "type": "integer", "minimum": 1 },
          "priceMax": { "type": "integer", "minimum": 1 },
          "paymentTerms": { "type": "string", "minLength": 1 },
          "assumptions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "risks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "upsells": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "mvpFirst": { "type": "boolean" },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["issue", "documentKey"],
            "properties": {
              "issue": { "type": "string", "const": "SNL-41" },
              "documentKey": { "type": "string", "const": "plan" }
            }
          }
        }
      }
    }
  }
}
