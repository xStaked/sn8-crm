generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CommercialBriefStatus {
  collecting
  ready_for_quote
  quote_in_review
  approved
}

enum QuoteDraftOrigin {
  initial
  regenerated
}

enum QuoteReviewStatus {
  pending_owner_review
  changes_requested
  ready_for_recheck
  approved
  delivered_to_customer
}

enum QuoteDraftDocumentKind {
  commercial_pdf
}

enum UserRole {
  admin
  user
}

enum WorkspaceMemberRole {
  owner
  admin
  operator
  reviewer
}

enum BotStatus {
  draft
  active
  paused
  archived
}

enum ChannelType {
  whatsapp
  instagram
  webchat
}

enum ChannelConnectionStatus {
  draft
  active
  error
  disconnected
}

enum ConversationStatus {
  open
  waiting_customer
  waiting_human
  closed
}

enum LeadStatus {
  new
  qualified
  unqualified
  won
  lost
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(user)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships WorkspaceMember[]
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members            WorkspaceMember[]
  bots               Bot[]
  channelConnections ChannelConnection[]
  conversations      Conversation[]
  leads              Lead[]
  messages           Message[]
  commercialBriefs   CommercialBrief[]
  quoteDrafts        QuoteDraft[]
  quoteReviewEvents  QuoteReviewEvent[]
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(operator)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Bot {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  status      BotStatus @default(draft)
  persona     Json?
  settings    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channelConnections ChannelConnection[]
  conversations      Conversation[]
  messages           Message[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
}

model ChannelConnection {
  id          String                  @id @default(cuid())
  workspaceId String
  botId       String?
  type        ChannelType
  name        String
  externalRef String?
  status      ChannelConnectionStatus @default(draft)
  credentials Json?
  settings    Json?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bot           Bot?            @relation(fields: [botId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  messages      Message[]

  @@index([workspaceId, type, status])
}

model Conversation {
  id                  String             @id @default(cuid())
  workspaceId         String
  botId               String?
  channelConnectionId String?
  externalThreadKey   String?
  customerPhone       String
  customerName        String?
  status              ConversationStatus @default(open)
  lastMessageAt       DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bot               Bot?               @relation(fields: [botId], references: [id], onDelete: SetNull)
  channelConnection ChannelConnection? @relation(fields: [channelConnectionId], references: [id], onDelete: SetNull)
  messages          Message[]
  lead              Lead?
  commercialBrief   CommercialBrief?

  @@unique([workspaceId, customerPhone])
  @@index([workspaceId, status, lastMessageAt])
  @@index([channelConnectionId])
}

model Lead {
  id             String     @id @default(cuid())
  workspaceId    String
  conversationId String?    @unique
  status         LeadStatus @default(new)
  fullName       String?
  phone          String?
  email          String?
  source         String?
  qualification  Json?
  profile        Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
}

model Message {
  id                  String    @id @default(cuid())
  workspaceId         String?
  conversationId      String?
  botId               String?
  channelConnectionId String?
  externalMessageId   String    @unique
  direction           String // "inbound" | "outbound"
  fromPhone           String
  toPhone             String
  body                String?
  channel             String    @default("whatsapp")
  rawPayload          Json
  processedAt         DateTime?
  createdAt           DateTime  @default(now())

  workspace    Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation?       @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  bot          Bot?                @relation(fields: [botId], references: [id], onDelete: SetNull)
  channelConn  ChannelConnection?  @relation(fields: [channelConnectionId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([conversationId, createdAt])
}

model ConversationState {
  id                   String   @id @default(cuid())
  conversationId       String   @unique
  state                String
  metadata             Json?
  offFlowCount         Int      @default(0)
  lastInboundMessageId String?
  lastTransitionAt     DateTime
  expiresAt            DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([expiresAt])
  @@index([state, lastTransitionAt])
}

model CommercialBrief {
  id                  String                @id @default(cuid())
  workspaceId         String?
  conversationId      String                @unique
  conversationRefId   String?
  status              CommercialBriefStatus @default(collecting)
  customerName        String?
  projectType         String?
  businessProblem     String?
  desiredScope        String?
  budget              String?
  urgency             String?
  constraints         String?
  summary             String?
  sourceTranscript    Json?
  conversationContext Json? // Stores topics, tone, concerns, urgency level, technical level
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  workspace           Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation        Conversation?         @relation(fields: [conversationRefId], references: [id], onDelete: SetNull)
  quoteDrafts         QuoteDraft[]

  @@index([status])
  @@index([workspaceId, status])
  @@index([conversationRefId])
}

model QuoteDraft {
  id                    String                  @id @default(cuid())
  workspaceId           String?
  commercialBriefId     String
  conversationId        String
  version               Int
  origin                QuoteDraftOrigin        @default(initial)
  reviewStatus          QuoteReviewStatus       @default(pending_owner_review)
  templateVersion       String?
  draftPayload          Json
  renderedQuote         String?
  ownerFeedbackSummary  String?
  approvedAt            DateTime?
  deliveredToCustomerAt DateTime?
  pricingRuleId         String?
  pricingRuleVersion    Int?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  workspace             Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  commercialBrief       CommercialBrief         @relation(fields: [commercialBriefId], references: [id], onDelete: Cascade)
  document              QuoteDraftDocument?
  pricingRule           PricingRule?            @relation(fields: [pricingRuleId], references: [id], onDelete: SetNull)
  estimateSnapshots     QuoteEstimateSnapshot[]
  outcomes              QuoteOutcome[]
  reviewEvents          QuoteReviewEvent[]

  @@unique([conversationId, version])
  @@index([commercialBriefId, version])
  @@index([conversationId, reviewStatus, createdAt])
  @@index([workspaceId, reviewStatus, createdAt])
  @@index([pricingRuleId, pricingRuleVersion, createdAt])
}

model PricingRule {
  id                String                  @id @default(cuid())
  name              String
  category          String
  complexity        String
  integrationType   String
  version           Int
  description       String?
  currency          String                  @default("COP")
  minMarginPct      Decimal                 @db.Decimal(5, 2)
  targetMarginPct   Decimal                 @db.Decimal(5, 2)
  maxMarginPct      Decimal                 @db.Decimal(5, 2)
  scoreWeights      Json?
  confidenceWeights Json?
  isActive          Boolean                 @default(true)
  archivedAt        DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  quoteDrafts       QuoteDraft[]
  estimateSnapshots QuoteEstimateSnapshot[]

  @@unique([category, complexity, integrationType, version])
  @@index([isActive, updatedAt])
  @@index([category, complexity, integrationType, isActive, version])
}

model QuoteEstimateSnapshot {
  id                    String        @id @default(cuid())
  conversationId        String
  quoteDraftId          String?
  pricingRuleId         String?
  currency              String        @default("COP")
  effortHours           Decimal?      @db.Decimal(10, 2)
  complexityScore       Decimal?      @db.Decimal(5, 2)
  confidencePct         Int?
  estimatedMinAmount    Decimal       @db.Decimal(14, 2)
  estimatedTargetAmount Decimal       @db.Decimal(14, 2)
  estimatedMaxAmount    Decimal       @db.Decimal(14, 2)
  breakdown             Json?
  inputPayload          Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  quoteDraft            QuoteDraft?   @relation(fields: [quoteDraftId], references: [id], onDelete: SetNull)
  pricingRule           PricingRule?  @relation(fields: [pricingRuleId], references: [id], onDelete: SetNull)
  outcome               QuoteOutcome?

  @@index([conversationId, createdAt])
  @@index([quoteDraftId, createdAt])
  @@index([pricingRuleId, createdAt])
}

model QuoteOutcome {
  id                      String                @id @default(cuid())
  conversationId          String
  quoteDraftId            String?
  quoteEstimateSnapshotId String                @unique
  currency                String                @default("COP")
  finalAmount             Decimal               @db.Decimal(14, 2)
  outcomeStatus           String
  closedAt                DateTime
  notes                   String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  quoteDraft              QuoteDraft?           @relation(fields: [quoteDraftId], references: [id], onDelete: SetNull)
  quoteEstimateSnapshot   QuoteEstimateSnapshot @relation(fields: [quoteEstimateSnapshotId], references: [id], onDelete: Cascade)

  @@index([conversationId, closedAt])
  @@index([quoteDraftId, closedAt])
  @@index([outcomeStatus, closedAt])
}

model QuoteDraftDocument {
  id             String                 @id @default(cuid())
  quoteDraftId   String                 @unique
  kind           QuoteDraftDocumentKind @default(commercial_pdf)
  fileName       String
  mimeType       String
  checksumSha256 String
  sizeBytes      Int
  content        Bytes
  generatedAt    DateTime               @default(now())
  quoteDraft     QuoteDraft             @relation(fields: [quoteDraftId], references: [id], onDelete: Cascade)

  @@index([kind, generatedAt])
}

model QuoteReviewEvent {
  id             String            @id @default(cuid())
  workspaceId    String?
  quoteDraftId   String
  conversationId String
  iteration      Int
  reviewStatus   QuoteReviewStatus
  feedback       String
  createdAt      DateTime          @default(now())
  resolvedAt     DateTime?
  workspace      Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  quoteDraft     QuoteDraft        @relation(fields: [quoteDraftId], references: [id], onDelete: Cascade)

  @@unique([quoteDraftId, iteration])
  @@index([workspaceId, createdAt])
  @@index([conversationId, createdAt])
}
